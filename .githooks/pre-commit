#!/bin/sh

echo "Running ruff check --fix..."
uv run ruff check --fix

echo "Running ruff format..."
uv run ruff format

if [ $? -ne 0 ]; then
  echo "ruff format failed"
  exit 1
fi

if ! git diff --quiet; then
  echo ""
  echo "Ruff changed files."
  echo "Please review changes, run git add, then commit again."
  exit 1
fi

exit 0